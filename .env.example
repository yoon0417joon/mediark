# Gallery Search System — 환경변수 예시
# 복사 후 .env 로 저장하고 필요한 값을 채운다.
# .env 파일은 절대 커밋하지 말 것 (.gitignore 포함)

# ── 갤러리 경로 ──────────────────────────────────────────────
GALLERY_ROOT=./images_sample
THUMB_DIR=./thumbs
SQLITE_PATH=./gallery.db
QDRANT_PATH=./qdrant_data

# ── 서버 바인드 ──────────────────────────────────────────────
# 127.0.0.1 = 이 PC에서만 접속 / 0.0.0.0 = 같은 네트워크 등 외부에서 접속 허용
# 주의: `uvicorn ... --host 127.0.0.1` 로 실행하면 여기 HOST 와 무관하게 루프백만 열림.
#       외부 개방 시: uvicorn server.main:app --host 0.0.0.0 --port 8000
#       또는: python -m server.main  (config 의 HOST/PORT 사용)
HOST=0.0.0.0
PORT=8000

# ── 보안 ─────────────────────────────────────────────────────
# API_KEY: 설정하면 X-API-Key 헤더 또는 Bearer 토큰(legacy) 필수
# 비워두면 loopback (127.0.0.1) 접근만 허용 — JWT 보유 시에는 원격도 허용
API_KEY=

# GET /thumb/*, /media/* 공개 읽기(토큰 없음). 기본 0 — 로그인 HttpOnly 쿠키로 충분.
# 1 이면 ID 를 아는 누구나 미디어 GET 가능(레거시·비공개 아님).
PUBLIC_MEDIA_GET=0

# ── 인증 (Sprint 15) ────────────────────────────────────────
# JWT_SECRET: HS256 서명 비밀 키. 32바이트 이상 권장.
#   비워두면 서버가 매 기동마다 임의 키 생성 → 모든 기존 토큰 무효화.
#   운영 환경에서는 반드시 고정된 값을 지정할 것.
JWT_SECRET=
JWT_ALGORITHM=HS256
JWT_TTL_MINUTES=1440

# HttpOnly 세션 쿠키(로그인 시 설정) — <img>/동일 출처 fetch 가 자동 전송
# HTTPS 운영 시 SESSION_COOKIE_SECURE=1 권장. SameSite=none 이면 Secure=1 필수(브라우저 정책).
SESSION_COOKIE_NAME=gallery_session
SESSION_COOKIE_SECURE=0
SESSION_COOKIE_SAMESITE=lax

# 부트스트랩 admin — 첫 기동 시 해당 이메일의 admin 계정이 없으면 생성.
# 두 변수 모두 설정해야 생성. 생성 후에는 값을 비워두거나 삭제해도 무방.
BOOTSTRAP_ADMIN_EMAIL=
BOOTSTRAP_ADMIN_PASSWORD=

# 로그인/가입 레이트리밋 (req/min/IP)
LOGIN_RATE_LIMIT=30

# 1 이면 초대 코드 없이 회원가입 허용 (OPEN_REGISTRATION_ROLE, 기본 viewer). 업로드는 uploader 이상 + 로그인 필요.
# 관리자 화면에서 공개 가입을 저장하면 app_settings 가 우선(미저장 시에만 아래 값 사용).
OPEN_REGISTRATION=0
OPEN_REGISTRATION_ROLE=viewer

# 미들웨어 전역 (req/min/IP, /thumb·/media 제외)
GLOBAL_RATE_LIMIT=2000

# ALLOWED_ORIGINS: CORS 허용 출처 (쉼표 구분). LAN IP 로 접속 시 해당 origin 추가 또는 끝에 * (개발용)
ALLOWED_ORIGINS=http://localhost,http://127.0.0.1,http://localhost:8000,http://127.0.0.1:8000,*

# ── 업로드 제한 ──────────────────────────────────────────────
MAX_UPLOAD_BYTES=524288000   # 500 MB
MAX_QUERY_LEN=256
SEARCH_RATE_LIMIT=90         # req/min/IP
UPLOAD_RATE_LIMIT=120        # req/min/IP

# ── Qdrant (외부 서비스 모드) ────────────────────────────────
# QDRANT_URL: 설정하면 로컬 임베디드 대신 HTTP 서비스 사용
QDRANT_URL=
QDRANT_API_KEY=

# ── OCR ─────────────────────────────────────────────────────
# OCR_BACKEND: "paddleocr" (Linux/Windows) | "easyocr" (macOS)
# 미지정 시 OS에 따라 자동 선택
OCR_BACKEND=
OCR_LANG=korean

# ── 태거 ─────────────────────────────────────────────────────
TAGGER_MODEL=SmilingWolf/wd-eva02-large-tagger-v3
TAGGER_THRESHOLD=0.35
RAM_MODEL=xinyu1205/recognize-anything-plus-model
RAM_IMAGE_SIZE=384
RAM_THRESHOLD=0.5

# ── 임베딩 ──────────────────────────────────────────────────
EMBED_MODEL=sentence-transformers/paraphrase-multilingual-mpnet-base-v2

# ── 영상 처리 ────────────────────────────────────────────────
VIDEO_SHORT_THRESHOLD=2      # 초 이하면 중간 프레임 1장만 추출
KEYFRAME_INTERVAL=2          # 키프레임 간격 (초)
MAX_MEDIA_DURATION=600       # 처리 최대 영상 길이 (초)
SUBPROCESS_TIMEOUT_SEC=600   # ffmpeg/ffprobe 프로세스 타임아웃 (초)

# ── STT ─────────────────────────────────────────────────────
STT_MODEL=base               # tiny | base | small | medium | large
STT_LANGUAGE=                # 미지정 시 자동 감지

# ── 썸네일 ──────────────────────────────────────────────────
THUMB_MAX_W=320
THUMB_MAX_H=320

# ── Watchdog ─────────────────────────────────────────────────
WATCHDOG_DEBOUNCE_SECONDS=3.0

# ── 기타 ─────────────────────────────────────────────────────
LIKE_FALLBACK_MAX_ROWS=5000
RATE_LIMIT_MAX_KEYS=5000
REBUILD_TAG_STATS_FULL_PIPELINE=0
