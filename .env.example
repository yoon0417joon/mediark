# Gallery Search System — 환경변수 예시
# 복사 후 .env 로 저장하고 필요한 값을 채운다.
# .env 파일은 절대 커밋하지 말 것 (.gitignore 포함)

# ── 갤러리 경로 ──────────────────────────────────────────────
GALLERY_ROOT=./images_sample
THUMB_DIR=./thumbs
SQLITE_PATH=./gallery.db
QDRANT_PATH=./qdrant_data

# ── 서버 바인드 ──────────────────────────────────────────────
HOST=127.0.0.1
PORT=8000

# ── 보안 ─────────────────────────────────────────────────────
# API_KEY: 설정하면 X-API-Key 헤더 또는 Bearer 토큰 필수
# 비워두면 loopback (127.0.0.1) 접근만 허용
API_KEY=

# ALLOWED_ORIGINS: CORS 허용 출처 (쉼표 구분)
ALLOWED_ORIGINS=http://localhost,http://127.0.0.1,http://localhost:8000,http://127.0.0.1:8000

# ── 업로드 제한 ──────────────────────────────────────────────
MAX_UPLOAD_BYTES=524288000   # 500 MB
MAX_QUERY_LEN=256
SEARCH_RATE_LIMIT=30         # req/min/IP
UPLOAD_RATE_LIMIT=60         # req/min/IP

# ── Qdrant (외부 서비스 모드) ────────────────────────────────
# QDRANT_URL: 설정하면 로컬 임베디드 대신 HTTP 서비스 사용
QDRANT_URL=
QDRANT_API_KEY=

# ── OCR ─────────────────────────────────────────────────────
# OCR_BACKEND: "paddleocr" (Linux/Windows) | "easyocr" (macOS)
# 미지정 시 OS에 따라 자동 선택
OCR_BACKEND=
OCR_LANG=korean

# ── 태거 ─────────────────────────────────────────────────────
TAGGER_MODEL=SmilingWolf/wd-eva02-large-tagger-v3
TAGGER_THRESHOLD=0.35
RAM_MODEL=xinyu1205/recognize-anything-plus-model
RAM_IMAGE_SIZE=384
RAM_THRESHOLD=0.5

# ── 임베딩 ──────────────────────────────────────────────────
EMBED_MODEL=sentence-transformers/paraphrase-multilingual-mpnet-base-v2

# ── 영상 처리 ────────────────────────────────────────────────
VIDEO_SHORT_THRESHOLD=2      # 초 이하면 중간 프레임 1장만 추출
KEYFRAME_INTERVAL=2          # 키프레임 간격 (초)
MAX_MEDIA_DURATION=600       # 처리 최대 영상 길이 (초)
SUBPROCESS_TIMEOUT_SEC=600   # ffmpeg/ffprobe 프로세스 타임아웃 (초)

# ── STT ─────────────────────────────────────────────────────
STT_MODEL=base               # tiny | base | small | medium | large
STT_LANGUAGE=                # 미지정 시 자동 감지

# ── 썸네일 ──────────────────────────────────────────────────
THUMB_MAX_W=320
THUMB_MAX_H=320

# ── Watchdog ─────────────────────────────────────────────────
WATCHDOG_DEBOUNCE_SECONDS=3.0

# ── 기타 ─────────────────────────────────────────────────────
LIKE_FALLBACK_MAX_ROWS=5000
RATE_LIMIT_MAX_KEYS=5000
REBUILD_TAG_STATS_FULL_PIPELINE=0
